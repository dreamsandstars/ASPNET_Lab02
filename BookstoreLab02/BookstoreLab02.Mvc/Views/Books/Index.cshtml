@model List<BookListItemViewModel>
@{
    ViewData["Title"] = "Danh mục Sách";
    var totalItems = Model.Count;
    var outOfStock = Model.Count(b => b.StockQuantity <= 0);
    var needReorder = Model.Count(b => b.StockQuantity > 0 && b.StockQuantity <= b.MinStock);
}

<div class="page-header">
    <div>
        <h2 class="page-title">Danh mục Sách.</h2>
        <p class="page-description">Quản lý và tra cứu các tựa sách trong cửa hàng.</p>
    </div>
    <div class="d-flex align-items-center gap-2">
        <form action="/Books" method="get" class="search-form d-flex">
            <input type="text" name="search" value="@ViewBag.Search" placeholder="Tìm tên sách..." class="form-control form-control-sm" style="border-radius: 100px 0 0 100px; width: 220px;">
            <button type="submit" class="btn btn-dark btn-sm" style="border-radius: 0 100px 100px 0;">Tìm</button>
        </form>
        @if (!string.IsNullOrEmpty(ViewBag.Search))
        {
            <a href="/Books" class="btn btn-outline-secondary btn-sm" style="border-radius: 100px; font-size: 0.75rem;">✕ Xóa lọc</a>
        }
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-4">
        <div class="stat-card-sm">
            <div class="stat-number-sm">@totalItems</div>
            <div class="stat-label-sm">Tổng tựa sách</div>
        </div>
    </div>
    <div class="col-4">
        <div class="stat-card-sm">
            <div class="stat-number-sm stat-danger">@outOfStock</div>
            <div class="stat-label-sm">Hết hàng</div>
        </div>
    </div>
    <div class="col-4">
        <div class="stat-card-sm">
            <div class="stat-number-sm stat-warning">@needReorder</div>
            <div class="stat-label-sm">Cần nhập</div>
        </div>
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="info-panel" style="justify-content:center;">
        Chưa có tựa sách nào trong kho.
    </div>
}
else
{
    <div style="overflow-x:auto;">
        <table class="table">
            <thead>
                <tr>
                    <th>ISBN</th>
                    <th>Tên Sách</th>
                    <th>Thể loại</th>
                    <th>NXB</th>
                    <th style="text-align:right;">Đơn giá</th>
                    <th style="text-align:center;">Tồn kho</th>
                    <th style="text-align:center;">Tình trạng</th>
                    <th style="text-align:center;">Đánh giá</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><code class="table-code">@item.Isbn</code></td>
                        <td class="table-title">@item.Title</td>
                        <td><span class="category-badge">@item.Category</span></td>
                        <td>@item.Publisher</td>
                        <td class="table-number">@item.PriceText</td>
                        <td class="table-mono">@item.StockQuantity</td>
                        <td style="text-align:center;">
                            <span class="@item.StockStatusClass">@item.StockStatus</span>
                        </td>
                        <td style="text-align:center;">
                            <span style="color:#f59e0b; font-size:0.85rem;">
                                @for(int i=1; i<=5; i++) {
                                    <span>@(i <= Math.Round(item.Rating) ? "★" : "☆")</span>
                                }
                            </span>
                            <div style="font-size:0.7rem; color:#9ca3af;">@item.Rating</div>
                        </td>
                        <td style="text-align:center;">
                            <a href="/Books/Detail/@item.Id" class="table-link">Chi tiết</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<div class="mt-4">
    <a class="btn btn-light" href="/">← Trang chủ</a>
</div>
