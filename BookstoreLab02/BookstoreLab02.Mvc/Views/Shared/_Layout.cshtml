<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Mini Bookstore</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold" href="/">Mini Bookstore</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link @(Context.Request.Path == "/" ? "active" : "")" href="/">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Books") && !Context.Request.Path.StartsWithSegments("/Books/Stats") ? "active" : "")" href="/Books">Kho Sách</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Books/Stats") ? "active" : "")" href="/Books/Stats">Thống kê</a>
                        </li>
                    </ul>
                    <span class="navbar-text" style="color:rgba(255,255,255,0.45);font-size:0.8rem;">
                        ASP.NET Core MVC Lab 02
                    </span>
                </div>
            </div>
        </nav>
    </header>

    <main class="container main-content">
        @RenderBody()
    </main>

    <footer class="footer border-top">
        <div class="container">
            &copy; 2026 — Mini Bookstore Catalog &nbsp;·&nbsp; ASP.NET Core MVC
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
